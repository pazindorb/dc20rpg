          "macros": {
            "preItemRoll": "switch(item.system.itemKey) {\n  case \"acolyte\": \n    enh.modifications.hasAdditionalFormula = true;\n    enh.modifications.additionalFormula = \"2\"\n    break;\n\n  case \"spellWarder\": \n    const macro = item.system.macros[\"3tIZMbkMmlYI5xkU\"].command;\n    item.system.macros[\"3tIZMbkMmlYI5xkU\"].command = macro.replace(\n      \"effect.changes[0].key = `system.damageReduction.damageTypes.${selected}.resist`;\",\n      \"effect.changes[0].key = `system.damageReduction.damageTypes.${selected}.resistance`; \\n effect.changes[0].value = true;\"\n    )\n    break;\n\n  case \"hexWarrior\":\n    const daze = item.getEffectByKey(\"hexWarriorsCurseDaze\");\n    const impaire = item.getEffectByKey(\"hexWarriorsCurseImpaire\");\n    if (daze) {\n      daze.changes[1].value = daze.changes[1].value.replace('\"value\": 1', `\"value\": ${1 + enh.number}`)\n    }\n    if (impaire) {\n      impaire.changes[1].value = impaire.changes[1].value.replace('\"value\": 1', `\"value\": ${1 + enh.number}`)\n    }\n    break;\n}",
