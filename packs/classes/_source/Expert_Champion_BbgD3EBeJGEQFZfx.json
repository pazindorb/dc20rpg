    "macros": {
      "0KMH3lQmUcCudO8P": {
        "command": "const adaptiveTactics = actor.getItemByKey(\"adaptiveTactics\");\nconst secondWind = actor.getEffectByKey(\"secondWind\");\n\nif (adaptiveTactics) {\n  const command = adaptiveTactics.system.macros.jUKSrdv202jBCDWB.command;\n  const newMacro = command.replace('const formula = tactic === \"assault\" ? \"d8\" : \"-d8\";', 'const formula = tactic === \"assault\" ? \"d10\" : \"-d10\";');\n  adaptiveTactics.update({[\"system.macros.jUKSrdv202jBCDWB.command\"]: newMacro})\n}\n\nif (secondWind) {\n  const command = secondWind.system.macro;\n  const newMacro = command.replaceAll(\"2\", \"4\").replace(\"DC40\", \"DC20\");\n  secondWind.update({[\"system.macro\"]: newMacro})\n}",
        "trigger": "onCreate",
        "disabled": false,
        "name": "Expert Champion",
        "title": "",
        "global": false
      },
      "DnXhJl1HEGerOGdV": {
        "command": "const adaptiveTactics = actor.getItemByKey(\"adaptiveTactics\");\nconst secondWind = actor.getEffectByKey(\"secondWind\");\n\nif (adaptiveTactics) {\n  const command = adaptiveTactics.system.macros.jUKSrdv202jBCDWB.command;\n  const newMacro = command.replace('const formula = tactic === \"assault\" ? \"d10\" : \"-d10\";', 'const formula = tactic === \"assault\" ? \"d8\" : \"-d8\";');\n  adaptiveTactics.update({[\"system.macros.jUKSrdv202jBCDWB.command\"]: newMacro})\n}\n\nif (secondWind) {\n  const command = secondWind.system.macro;\n  const newMacro = command.replaceAll(\"4\", \"2\");\n  secondWind.update({[\"system.macro\"]: newMacro})\n}",
