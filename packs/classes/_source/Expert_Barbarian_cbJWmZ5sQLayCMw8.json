          "macros": {
            "preItemRoll": "const fortitudeShout = item.getEffectByKey(\"fortitudeShout\");\nif (!fortitudeShout) return;\n\nfortitudeShout.name = \"Enhanced Fortitude Shout\"\n\n// Corrosion\nfortitudeShout.changes[0].value = true;\nfortitudeShout.changes[0].key = \"system.damageReduction.damageTypes.corrosion.resistance\";\nfortitudeShout.changes[0].mode = 5;\n\n// Fire\nfortitudeShout.changes[1].value = true;\nfortitudeShout.changes[1].key = \"system.damageReduction.damageTypes.fire.resistance\";\nfortitudeShout.changes[1].mode = 5;\n\n// Cold\nfortitudeShout.changes[2].value = true;\nfortitudeShout.changes[2].key = \"system.damageReduction.damageTypes.cold.resistance\";\nfortitudeShout.changes[2].mode = 5;\n\n// Lightning\nfortitudeShout.changes[3].value = true;\nfortitudeShout.changes[3].key = \"system.damageReduction.damageTypes.lightning.resistance\";\nfortitudeShout.changes[3].mode = 5;\n\n// Poison\nfortitudeShout.changes[4].value = true;\nfortitudeShout.changes[4].key = \"system.damageReduction.damageTypes.poison.resistance\";\nfortitudeShout.changes[4].mode = 5;\n\n// Piercing\nfortitudeShout.changes[5].value = true;\nfortitudeShout.changes[5].key = \"system.damageReduction.damageTypes.piercing.resistance\";\nfortitudeShout.changes[5].mode = 5;\n\n// Slashing\nfortitudeShout.changes[6].value = true;\nfortitudeShout.changes[6].key = \"system.damageReduction.damageTypes.slashing.resistance\";\nfortitudeShout.changes[6].mode = 5;\n\n// Bludgeoning\nfortitudeShout.changes[7].value = true;\nfortitudeShout.changes[7].key = \"system.damageReduction.damageTypes.bludgeoning.resistance\";\nfortitudeShout.changes[7].mode = 5;",
