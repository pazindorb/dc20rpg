    "macros": {
      "yEU39bFjKEhi6OTW": {
        "command": "const naturesTorrent = actor.getItemByKey(\"naturesTorrent\");\nconst druidDomain = actor.getItemByKey(\"druidDomain\");\nconst wildGrowth = actor.getItemByKey(\"wildGrowth\");\nconst wildGrowthMacro = 'const wildGrowth = item.getEffectByKey(\"wildGrowth\");\\nif (!wildGrowth) return;\\n'\n  + 'wildGrowth.changes[0].value = `\"eventType\": \"healing\", \"trigger\": \"turnEnd\", \"label\": \"Wild Growth - Healing\", \"preTrigger\": \"skip\", \"value\": ${enh.number + 1}, \"type\": \"heal\", \"actorId\": \"#SPEAKER_ID#\"`'\n\nif (druidDomain) {\n  druidDomain.update({[\"system.target.areas.default.distance\"]: 10})\n  druidDomain.createNewEnhancement({\n    name: \"Expert Druid\", \n    description: \"You can spend additional MP when you use Druid Domain to increase the number of Domain Spaces created by 8 per additional MP spent.\",\n    resources: {mana: 1}\n  }, \"expertDruid\")\n}\n\nif (wildGrowth) {\n  wildGrowth.createNewEnhancement({\n    name: \"Expert Druid\", \n    description: \"You can spend additional MP to increase the healing by 1 per 2 additional MP spent.\",\n    resources: {mana: 2},\n    modifications: {\n      hasAdditionalFormula: true,\n      additionalFormula: \"1\",\n      macros: {\n        preItemRoll: wildGrowthMacro,\n        postItemRoll: \"\"\n      },\n    }\n  }, \"expertDruid\")\n}\n\nif (naturesTorrent) {\n  naturesTorrent.update({[\"system.range.normal\"]: 15})\n}",
        "trigger": "onCreate",
        "disabled": false,
        "name": "Expert Druid",
        "title": "",
        "global": false
      },
      "63VqeFOZcNM7JDd4": {
        "command": "const naturesTorrent = actor.getItemByKey(\"naturesTorrent\");\nconst druidDomain = actor.getItemByKey(\"druidDomain\");\nconst wildGrowth = actor.getItemByKey(\"wildGrowth\");\n\nif (druidDomain) {\n  druidDomain.update({[\"system.target.areas.default.distance\"]: 8})\n  druidDomain.removeEnhancement(\"expertDruid\")\n}\n\nif (wildGrowth) {\n  wildGrowth.removeEnhancement(\"expertDruid\")\n}\n\nif (naturesTorrent) {\n  naturesTorrent.update({[\"system.range.normal\"]: 10})\n}",
        "trigger": "preDelete",
