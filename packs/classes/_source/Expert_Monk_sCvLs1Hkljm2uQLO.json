    "macros": {
      "yEU39bFjKEhi6OTW": {
        "command": "const spiritualBalance = actor.getItemByKey(\"spiritualBalance\");\nconst unarmedStrike = actor.getItemByKey(\"unarmedStrike\");\n\nif (spiritualBalance) {\n  spiritualBalance.update({\n    [\"system.macros.4VSp4y3mDjP1jo0Q.command\"]: 'actor.resources[\"ki-point\"].regain(\"half\")'\n  })\n}\n\nif (unarmedStrike) {\n  const selected = await DC20.dialog.SimplePopup.select(\"Select second Unarmed Strike Weapon Style\", CONFIG.DC20RPG.DROPDOWN_DATA.meleeWeaponStyles);\n  const weaponStyle = actor.getItemByKey(`${selected}Style`);\n  if (weaponStyle) {\n    const copyFor = weaponStyle.system.copyEnhancements.copyFor;\n    const newCopyFor = copyFor + '||system.itemKey=[\"unarmedStrike\"]'\n    weaponStyle.update({[\"system.copyEnhancements.copyFor\"]: newCopyFor})\n    item.update({[\"flags.dc20rpg.selectedWeaponStyle\"]: weaponStyle.id})\n  }\n}",
        "trigger": "onCreate",
        "disabled": false,
        "name": "Expert Monk",
        "title": "",
        "global": false
      },
      "63VqeFOZcNM7JDd4": {
        "command": "const spiritualBalance = actor.getItemByKey(\"spiritualBalance\");\nconst unarmedStrike = actor.getItemByKey(\"unarmedStrike\");\n\nif (spiritualBalance) {\n  spiritualBalance.update({\n    [\"system.macros.4VSp4y3mDjP1jo0Q.command\"]: 'actor.resources[\"ki-point\"].regain(1)'\n  })\n}\n\nif (unarmedStrike) {\n  const weaponStyleId = item.flags.dc20rpg.selectedWeaponStyle;\n  const weaponStyle = actor.items.get(weaponStyleId);\n  if (weaponStyle) {\n    const copyFor = weaponStyle.system.copyEnhancements.copyFor;\n    const newCopyFor = copyFor.replace('||system.itemKey=[\"unarmedStrike\"]', \"\")\n    weaponStyle.update({[\"system.copyEnhancements.copyFor\"]: newCopyFor})\n  }\n}",
        "trigger": "preDelete",
        "disabled": false,
        "name": "Remove Expert Monk",
        "title": "",
        "global": false
      }
