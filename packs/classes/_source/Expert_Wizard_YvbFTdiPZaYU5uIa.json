    "macros": {
      "yEU39bFjKEhi6OTW": {
        "command": "const preparedSpell = actor.getItemByKey(\"preparedSpell\");\nconst spellSchoolInitiate = actor.getItemByKey(\"spellSchoolInitiate\");\n\nif (spellSchoolInitiate) {\n  spellSchoolInitiate.update({[\"system.costs.charges.maxChargesFormula\"]: \"2\"});\n}\n\nif (preparedSpell) {\n  const macro = foundry.utils.deepClone(item.system.macros[\"bIByN946kZ5hycDE\"]);\n  if (!macro) return;\n  \n  macro.disabled = false;\n  await preparedSpell.createNewItemMacro(macro, \"expertWizard\")\n  await preparedSpell.update({\n    [\"system.macros.aoRqwlzsx20HfJzL.disabled\"]: true,\n    [\"system.costs.charges.maxChargesFormula\"]: \"2\"\n  })\n  preparedSpell.callMacroWithKey(\"expertWizard\", {});\n}",
        "trigger": "onCreate",
        "disabled": false,
        "name": "Expert Wizard",
        "title": "",
        "global": false
      },
      "63VqeFOZcNM7JDd4": {
        "command": "const preparedSpell = actor.getItemByKey(\"preparedSpell\");\nconst spellSchoolInitiate = actor.getItemByKey(\"spellSchoolInitiate\");\n\nif (spellSchoolInitiate) {\n  spellSchoolInitiate.update({[\"system.costs.charges.maxChargesFormula\"]: \"2\"});\n}\n\nif (preparedSpell) {\n  await preparedSpell.removeItemMacro(\"expertWizard\");\n  await preparedSpell.update({\n    [\"system.macros.aoRqwlzsx20HfJzL.disabled\"]: false,\n    [\"system.costs.charges.maxChargesFormula\"]: \"1\"\n  })\n  preparedSpell.callMacroWithKey(\"aoRqwlzsx20HfJzL\", {});\n}",
        "trigger": "preDelete",
        "disabled": false,
        "name": "Remove Expert Wizard",
        "title": "",
        "global": false
      },
      "bIByN946kZ5hycDE": {
        "command": "// 1. Select Spell\nconst spells = actor.getAllItemsWithType([\"spell\"], [], true);\nconst firstSpell = await DC20.dialog.SimplePopup.select(\"Select First Spell for your Prepared Spell\", spells);\nconst secondSpell = await DC20.dialog.SimplePopup.select(\"Select Second Spell for your Prepared Spell\", spells);\n\nawait item.update({[\"system.copyEnhancements.copyFor\"]: `id=[\"${firstSpell}\", \"${secondSpell}\"]`});",
        "trigger": "onDemand",
        "disabled": true,
        "name": "Change Prepared Spell",
        "title": "Change Prepared Spell",
        "global": false
      }
    },
