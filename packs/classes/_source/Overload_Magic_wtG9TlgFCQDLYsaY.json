        "trigger": "preItemRoll",
        "command": "const attribute = await DC20.dialog.SimplePopup.select(\"Select Attribute Save\", {mig: \"Might Save\", agi: \"Agility Save\", int: \"Intelligence Save\", cha: \"Charisma Save\"});\nif (!attribute) return;\n\nitem.system.rollRequests.w7ReGBBbWsOnfge9.saveKey = attribute;\nitem.update({[\"system.rollRequests.w7ReGBBbWsOnfge9.saveKey\"]: attribute});"
