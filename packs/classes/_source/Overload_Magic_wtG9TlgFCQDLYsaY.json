        "name": "Prepare Overload Magic Effect",
        "trigger": "onItemToggle",
        "command": "if(on) {\n  const effect = item.effects.get(\"IE9L3PWryvMuI3IG\");\n  if(!effect) return;\n\n  const attribute = item.system?.rollRequests?.w7ReGBBbWsOnfge9?.saveKey || \"mig\";\n  const spellDC = actor.system.saveDC.value.spell;\n  const value = effect.system.changes[1].value;\n  const newValue = value\n                    .replace(/(\"against\":\\s*)[^,]+/g, `$1${spellDC}`)\n                    .replace(/(\"checkKey\"\\s*:\\s*\")(?:mig|agi|int|cha)(\")/g,`$1${attribute}$2`);\n  effect.system.changes[1].value = newValue;\n  effect.update({[\"system.changes\"]: effect.system.changes});\n}",
        "disabled": false,
        "title": ""
      },
