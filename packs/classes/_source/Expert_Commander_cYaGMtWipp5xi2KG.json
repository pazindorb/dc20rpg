    "macros": {
      "yEU39bFjKEhi6OTW": {
        "command": "const inspiringPresence = actor.getItemByKey(\"inspiringPresence\");\nconst commandingAura = actor.getItemByKey(\"commandingAura\");\nconst commandersCall = actor.getItemByKey(\"commandersCall\");\n\nif (inspiringPresence) {\n  inspiringPresence.update({[\"system.formulas.jQMiuxzjgEvWvhVU.formula\"]: \"2\"});\n}\n\nif (commandingAura) {\n  commandingAura.update({[\"system.enhancements.9bbQvJPVQhAvTT4H.modifications.macros.preItemRoll\"]: \"actor.system.help.maxDice = 10\"});\n}\n\nif (commandersCall) {\n  commandersCall.update({[\"system.range.normal\"]: 10})\n  commandersCall.createNewEnhancement({\n    name: \"Expert Commander\", \n    description: \"When you use Commander’s Call, you can spend 2 additional SP to issue the creature 1 additional command of your choice. The creature chooses the order in which it resolves the granted commands.\",\n    resources: {stamina: 2}\n  }, \"expertCommander\")\n}",
        "trigger": "onCreate",
        "disabled": false,
        "name": "Expert Commander",
        "title": "",
        "global": false
      },
      "63VqeFOZcNM7JDd4": {
        "command": "const inspiringPresence = actor.getItemByKey(\"inspiringPresence\");\nconst commandingAura = actor.getItemByKey(\"commandingAura\");\nconst commandersCall = actor.getItemByKey(\"commandersCall\");\n\nif (inspiringPresence) {\n  inspiringPresence.update({[\"system.formulas.jQMiuxzjgEvWvhVU.formula\"]: \"1\"});\n}\n\nif (commandingAura) {\n  commandingAura.update({[\"system.enhancements.9bbQvJPVQhAvTT4H.modifications.macros.preItemRoll\"]: \"\"});\n}\n\nif (commandersCall) {\n  commandersCall.update({[\"system.range.normal\"]: 5 })\n  commandersCall.removeEnhancement(\"expertCommander\")\n}",
        "trigger": "preDelete",
        "disabled": false,
        "name": "Remove Expert Commander",
        "title": "",
        "global": false
      }
