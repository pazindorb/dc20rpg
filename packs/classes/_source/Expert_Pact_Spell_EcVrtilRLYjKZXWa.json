    "macros": {
      "zIePV2PK1RvAqWtP": {
        "command": "const spells = actor.getAllItemsWithType([\"spell\"], [], true);\nconst first = await DC20.dialog.SimplePopup.select(\"Select Pact Spell\", spells);\nconst second = await DC20.dialog.SimplePopup.select(\"Select Second Pact Spell\", spells);\nif (!first || !second) return;\n\nconst firstSpell = actor.items.get(first);\nconst secondSpell = actor.items.get(second);\nif (!firstSpell || !secondSpell) return;\n\nconst oldFirstSpell = actor.items.get(item.flags?.dc20rpg?.pactSpell);\nif (oldFirstSpell) await oldFirstSpell.update({[\"flags.dc20rpg.-=pactItem\"]: null});\n\nconst oldSecondSpell = actor.items.get(item.flags?.dc20rpg?.pactSpellSecond);\nif (oldSecondSpell) await oldSecondSpell.update({[\"flags.dc20rpg.-=pactItem\"]: null});\n\nfirstSpell.update({[\"flags.dc20rpg.pactItem\"]: true});\nsecondSpell.update({[\"flags.dc20rpg.pactItem\"]: true});\nitem.update({\n  [\"flags.dc20rpg.pactSpell\"]: first,\n  [\"flags.dc20rpg.pactSpellSecond\"]: second,\n  [\"system.conditional.useFor\"]: `id=[\"${first}\", \"${second}\"]`,\n  [\"system.copyEnhancements.copyFor\"]: `id=[\"${first}\", \"${second}\"]`,\n});",
        "trigger": "onDemand",
        "disabled": true,
        "name": "Change Pact Spell",
        "title": "Change Pact Spell",
        "global": false
      },
      "T6DG8QITgcc4V2th": {
        "command": "const pactSpell = actor.getItemByKey(\"pactSpell\");\nif (!pactSpell) return;\n\nconst macro = foundry.utils.deepClone(item.system.macros[\"zIePV2PK1RvAqWtP\"]);\nif (!macro) return;\n\nmacro.disabled = false;\nawait pactSpell.createNewItemMacro(macro, \"expertPactSpell\")\nawait pactSpell.update({[\"system.macros.kUAVt5aTiQUVOins.disabled\"]: true})\npactSpell.callMacroWithKey(\"expertPactSpell\", {});",
        "trigger": "onCreate",
        "disabled": false,
        "name": "Add Expert Pact Spell",
        "title": "",
        "global": false
      },
      "L6g13TBriz8lH2AK": {
        "command": "const pactSpell = actor.getItemByKey(\"pactSpell\");\nif (!pactSpell) return;\n\nawait pactSpell.removeItemMacro(\"expertPactSpell\");\nawait pactSpell.update({[\"system.macros.kUAVt5aTiQUVOins.disabled\"]: false})\npactSpell.callMacroWithKey(\"kUAVt5aTiQUVOins\", {});",
        "trigger": "preDelete",
        "disabled": false,
        "name": "Remove Expert Pact Spell",
        "title": "",
        "global": false
      }
    },
