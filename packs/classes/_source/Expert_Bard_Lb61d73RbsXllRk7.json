      "0KMH3lQmUcCudO8P": {
        "command": "const bardicPerformance = actor.getItemByKey(\"bardicPerformance\");\nif (!bardicPerformance) return;\n\nconst emotional = bardicPerformance.enhancements.maintained.get(\"Ouwdlwkqsy5xFbj7\");\nconst current = emotional.modifications.macros.preItemRoll;\nconst newMacro = 'if (item.enhancements.active.has(\"P8rCmPk1baFtENkE\")) return;\\n' + current;\nbardicPerformance.update({[\"system.enhancements.Ouwdlwkqsy5xFbj7.modifications.macros.preItemRoll\"]: newMacro});",
