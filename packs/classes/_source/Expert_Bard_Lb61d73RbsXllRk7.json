          "addsEffect": null,
          "macros": {
            "preItemRoll": "const battleBallad = item.enhancements.active.get(\"GL3MZ5TT0EA8vcbf\");\nconst fastTempo = item.enhancements.active.get(\"v0YjX5gvDi9OPeLq\");\nconst inspiring = item.enhancements.active.get(\"YmRa89r1AW92xlms\");\nconst emotional = item.enhancements.active.get(\"Ouwdlwkqsy5xFbj7\");\n\nif (battleBallad) {\n  battleBallad.modifications.addsEffect.name = \"Improved Battle Ballad\"\n  battleBallad.modifications.addsEffect.changes[1].value = '\"value\": 0, \"label\": \"Improved Battle Ballad\", \"modifier\": \"+ 1d8\", \"afterRoll\": \"disable\"'\n  battleBallad.modifications.addsEffect.changes[2].value = '\"value\": 0, \"label\": \"Improved Battle Ballad\", \"modifier\": \"+ 1d8\", \"afterRoll\": \"disable\"'\n  battleBallad.modifications.addsEffect.changes[3].value = '\"value\": 0, \"label\": \"Improved Battle Ballad\", \"modifier\": \"+ 1d8\", \"afterRoll\": \"disable\"'\n  battleBallad.modifications.addsEffect.changes[4].value = '\"value\": 0, \"label\": \"Improved Battle Ballad\", \"modifier\": \"+ 1d8\", \"afterRoll\": \"disable\"'\n  battleBallad.modifications.addsEffect.changes[5].value = '\"value\": 0, \"label\": \"Improved Battle Ballad\", \"modifier\": \"+ 1d8\", \"afterRoll\": \"disable\"'\n  battleBallad.modifications.addsEffect.changes[6].value = '\"value\": 0, \"label\": \"Improved Battle Ballad\", \"modifier\": \"+ 1d8\", \"afterRoll\": \"disable\"'\n}\n\nif (fastTempo) {\n  fastTempo.modifications.addsEffect.name = \"Improved Fast Tempo\"\n  fastTempo.modifications.addsEffect.changes[0].value = 3\n}\n\nif (inspiring) {\n  inspiring.modifications.addsEffect.name = \"Improved Inspiring\"\n  inspiring.modifications.addsEffect.changes[0].value = '\"eventType\":\"healing\", \"trigger\":\"turnStart\", \"value\":\"2\", \"type\": \"temporary\", \"label\": \"Improved Inspiring\"'\n}\n\nif (emotional) {\n  emotional.modifications.addsEffect.name = \"Improved Emotional\"\n  emotional.modifications.addsEffect.changes = [\n    {key: \"system.statusResistances.charmed.resistance\", mode: 5, value: 1},\n    {key: \"system.statusResistances.intimidated.resistance\", mode: 5, value: 1},\n    {key: \"system.statusResistances.frightened.resistance\", mode: 5, value: 1},\n    {key: \"system.statusResistances.taunted.resistance\", mode: 5, value: 1}\n  ]\n}",
