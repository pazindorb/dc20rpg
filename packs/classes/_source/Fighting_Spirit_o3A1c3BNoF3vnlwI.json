    "macros": {
      "MWR4SWwQdnR1rWjz": {
        "name": "Combat Readiness",
        "trigger": "preItemRoll",
        "command": "const selectOptions = {\n  fortify: \"Fortify\",\n  advance: \"Advance\"\n}\nconst selected = await DC20.dialog.SimplePopup.select(\"Choose Combat Readiness Benefit\", selectOptions);\n\n//===============//\n//    FORTIFY    //\n//===============//\nif (selected === \"fortify\") {\n  // Dodge\n  const dodgeEffect = item.getEffectByKey(\"dodge\");\n  if (dodgeEffect) await DC20.DC20RpgActiveEffect.gmCreate(dodgeEffect.toObject(), {parent: actor});\n  \n\n  // ADV on next Save\n  const fortify = item.getEffectByKey(\"fortify\");\n  if (fortify) await DC20.DC20RpgActiveEffect.gmCreate(fortify.toObject(), {parent: actor});\n}\n\n//=================//\n//     ADVANCE     //\n//=================//\nif (selected === \"advance\") { \n  // Move Action\n  actor.moveAction();\n\n  // ADV on next Physical Check\n  const advance = item.getEffectByKey(\"advance\");\n  if (advance) await DC20.DC20RpgActiveEffect.gmCreate(advance.toObject(), {parent: actor});\n}",
        "disabled": false,
        "title": ""
      }
