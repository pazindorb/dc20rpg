      "3tIZMbkMmlYI5xkU": {
        "name": "Create Spell Warder effect",
        "trigger": "postItemRoll",
        "command": "const alreadyActive = actor.getEffectByKey(\"spellWarder\");\nconst damageTypes = {\n  ...CONFIG.DC20RPG.DROPDOWN_DATA.elementalDamageTypes,\n  ...CONFIG.DC20RPG.DROPDOWN_DATA.mysticalDamageTypes\n}\nconst selected = await DC20.dialog.SimplePopup.select(\"Select Resitance Type\", damageTypes);\nif (!selected) return;\n\nconst eff = item.getEffectByKey(\"spellWarder\");\nconst effect = eff.toObject()\neffect.changes[0].key = `system.damageReduction.damageTypes.${selected}.resist`;\neffect.name = `Spell Warder (${damageTypes[selected]})`\n\nif (alreadyActive) alreadyActive.delete();\ngame.dc20rpg.effects.createEffectOn(effect, actor);",
