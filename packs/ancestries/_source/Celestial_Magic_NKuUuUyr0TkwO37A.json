    "choicePointCost": 2,
    "hasAdvancement": true,
    "advancements": {
      "default": {
        "name": "Celestial Magic",
        "allowToAddItems": true,
        "compendium": "spell",
        "customTitle": "Celestial Magic - You learn 1 Spell from the Divine Spell List",
        "items": {},
        "addItemsOptions": {
          "itemType": "spell",
          "itemLimit": 1,
          "helpText": "Add Celestial Magic Spell",
          "preFilters": "{\"spellSource\": {\"arcane\": false, \"divine\": true, \"primal\": false}}"
        },
        "macro": "if (!advancement.items) {\n  ui.notifications.error(\"Celestial Magic Spell not found - Add it manually by running on demand macro\");\n  return;\n}\nconst items = Object.values(advancement.items);\nconst spell = items[0];\n\nif (!spell) {\n  ui.notifications.error(\"Celestial Magic Spell not found - Add it manually by running on demand macro\");\n  return;\n}\nelse {\n  const celestialMagic = actor.getItemByKey(\"celestialMagic\");\n  if (celestialMagic) {\n    celestialMagic.update({\n      [\"system.copyEnhancements.copyFor\"]: `id=[\"${spell.createdItemId}\"]`,\n      [\"system.shortInfo\"]: `Selected Spell: ${spell.name}`,\n      [\"flags.dc20rpg.currentSpellId\"]: spell.createdItemId\n    });\n  }\n}",
        "doNotAddToKnownLimit": true,
        "key": "default"
      }
    },
    "macros": {
      "I2oxNQOghZGdmsCE": {
        "name": "Change Celestial Magic Spell",
        "trigger": "onDemand",
        "command": "const options = actor.getAllItemsWithType([\"spell\"], [], true);\nconst spellId = await DC20.dialog.SimplePopup.select(\"Select Celestial Magic Spell\", options);\nif (!spellId) return;\n\nconst currentSpellId = item.flags.dc20rpg.currentSpellId;\nif (currentSpellId === spellId) return;\n\nconst currentSpell = actor.items.get(currentSpellId);\nif (currentSpell) currentSpell.update({[\"system.knownLimit\"]: true});\nconst newSpell = actor.items.get(spellId);\nif (newSpell) newSpell.update({[\"system.knownLimit\"]: false});\n\nitem.update({\n  [\"system.copyEnhancements.copyFor\"]: `id=[\"${spellId}\"]`,\n  [\"system.shortInfo\"]: `Selected Spell: ${options[spellId]}`,\n  [\"flags.dc20rpg.currentSpellId\"]: spellId\n});",
        "disabled": false,
        "title": "Change Celestial Magic Spell"
      }
