        "macro": "// We want to skip this if actor is the caster. Not the best solution but I have no time to make it better now.\nif (actor.getItemByKey(\"unholyAura\")) return;\n\n// We dont want to call it too fast as some tokens might be inside that template at the time we place it.\nconst skipTime = 5000 // 5 sec\nconst templateCallTime = effect.flags.dc20rpg?.templateCallTime || 0;\nconst effectCreationTime = effect._stats.createdTime\nif (event.trigger === \"instant\" && effectCreationTime - templateCallTime < skipTime) return;\n\nif (event.trigger === \"instant\" && !actor.myTurnActive) return;\n\n// If fail apply Doomed\nconst message = game.messages.get(effect.system.chatMessageId);\nif (!message) {\n  ui.notifications.notify(\"'Unholy Aura' chat message not found. Cannot apply the effect.\");\n  return;\n}\nconst doomed = message.system.applicableEffects.find(effect => effect.system.effectKey === \"doomedUnholyAura\");\nif (!doomed) {\n  ui.notifications.notify(\"'Doomed - Unholy Aura' effect not found on chat message.\");\n  return;\n}\n\nconst details = DC20.DC20Roll.prepareSaveDetails(\"cha\", {against: event.against, statuses: [\"doomed\"], rollTitle: event.label});\nconst roll = await DC20.dialog.RollDialog.open(actor, details, {sendToActorOwners: true});\nif (roll && (roll._total < event.against)) {\n  game.dc20rpg.effects.createEffectOn(doomed, actor);\n}",
