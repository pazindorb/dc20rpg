    "macros": {
      "Xw63KTRMLdajHFHg": {
        "command": "const effect = item.getEffectByKey(\"enfeeble\");\nif (!effect) return;\n\nconst enhancements = item.enhancements.active;\n\n// Greater Enfeeble Active \nconst greaterEnfeeble = enhancements.get(\"2V0UDp6caiOiYgJj\");\nif (greaterEnfeeble) {\n  effect.flags.dc20rpg = {greaterEnfeeble: greaterEnfeeble.number};\n}\n\n// Full Enfeeble Active - nothing more to do here\nif (enhancements.get(\"6I4hf5EzKEwUw3Ki\")) return;\n\n// Select Curse\nlet enfeeble = await DC20.dialog.SimplePopup.select(\"Select Attributes\", {phy: \"Physical\", men: \"Mental\"});\n\nconst newChanges = [];\nfor (const change of effect.system.changes) {\n  if (change.key.includes(\"events\")) newChanges.push(change);\n\n  if (change.key.includes(\".mig\") && enfeeble === \"phy\") newChanges.push(change);\n  if (change.key.includes(\".agi\") && enfeeble === \"phy\") newChanges.push(change);\n  if (change.key.includes(\".mar\") && enfeeble === \"phy\") newChanges.push(change);\n\n  if (change.key.includes(\".int\") && enfeeble === \"men\") newChanges.push(change);\n  if (change.key.includes(\".cha\") && enfeeble === \"men\") newChanges.push(change);\n  if (change.key.includes(\".spe\") && enfeeble === \"men\") newChanges.push(change);\n}\neffect.system.changes = newChanges;",
        "trigger": "preItemRoll",
