    "macros": {
      "NAW3UGqsTQuVHlOD": {
        "command": "const effect = item.effects.get(\"AM4osJFrYy5BcWFp\");\nif (!effect) return;\neffect.flags.dc20rpg.enhancements = foundry.utils.deepClone(item.system.enhancements)\neffect.system.macro = `\nif (event.trigger === \"instant\") {\n  const enhancements = effect.flags.dc20rpg.enhancements;\n  const damageEnh = enhancements[\"M3kqvvdUP8iOx4PG\"];\n  const illuminating = enhancements[\"YbloHZiXtY6KLTaD\"];\n  const guiding = enhancements[\"DGBpMC90MFNKfzP2\"];\n\n  const damage = 1 + damageEnh.number;\n  const dmgFormula = new DC20.Formula();\n  dmgFormula.formula = damage + \"\";\n  dmgFormula.type = \"radiant\";\n  const modifications = {\n    addsNewFormula: true,\n    formula: dmgFormula\n  }\n\n  let description = \"<p>You deal + \" + damage + \" Radiant Damage on Martial Attacks</p>\"\n  if (illuminating.number > 0) {\n    description += illuminating.description;\n    modifications.addsNewRollRequest = true;\n    modifications.rollRequest = illuminating.modifications.rollRequest;\n  }\n\n  if (guiding.number > 0) {\n    description += guiding.description;\n    modifications.addsNewRollRequest = true;\n    modifications.rollRequest = guiding.modifications.rollRequest;\n    modifications.addsEffect = guiding.modifications.addsEffect;\n  }\n\n  const enhancement = {\n    name: \"Radiant Strikes\",\n    img: effect.img,\n    description: description,\n    copyFor: \"isMartialAttack=[true]\",\n    modifications: modifications,\n    repeatable: false\n  }\n  actor.enhancements.add(enhancement, {key: \"radiantImbued\"})\n}\n\n\nif (event.trigger === \"effectRemoved\") {\n  actor.enhancements.delete(\"radiantImbued\");\n}\n`",
        "trigger": "postItemRoll",
        "disabled": false,
        "name": "Prepare Radiant Imbued Effect Macro",
        "title": "",
        "global": false
      }
