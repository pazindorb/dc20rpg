            "preItemRoll": "const mockery = item.getEffectByKey(\"mockery\");\nif (!mockery) return;\n\nmockery.statuses.add(\"blinded\", \"deafened\")\n\n// Add Deafened effect\nmockery.changes.push({\n  key: \"system.dynamicRollModifier.onYou.skills\", \n  mode: 2, \n  value: '\"label\": \"Deafened\", \"confirmation\": true, \"autoFail\": true, \"skill\": \"awa\"'})\n\n// Add Blind effect\nconst blindKeys = [\n  \"system.dynamicRollModifier.onYou.attack\",\n  \"system.dynamicRollModifier.againstYou.attack\",\n];\nconst blindValue = '\"value\": 1, \"type\": \"dis\", \"label\": \"Blinded\", \"confirmation\": true';\n\nmockery.system.changes.push({\n  key: \"system.dynamicRollModifier.onYou.skills\", \n  mode: 2, \n  value: '\"label\": \"Blinded\", \"confirmation\": true, \"autoFail\": true, \"skill\": \"awa\"'})\nfor (const key of blindKeys) {\n  mockery.system.changes.push({key: key, mode: 2, value: blindValue})\n}",
