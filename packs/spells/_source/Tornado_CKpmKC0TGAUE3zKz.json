        "effectKey": "tornado",
        "macro": "const increasedPush = effect.flags.dc20rpg?.increasedPush || 0;\nconst stormCore = effect.flags.dc20rpg?.stormCore || 0;\nconst updraft = effect.flags.dc20rpg?.updraft || 0;\n\n// We dont want to call it too fast as some tokens might be inside that template at the time we place it.\nconst skipTime = 5000 // 5 sec\nconst templateCallTime = effect.flags.dc20rpg?.templateCallTime || 0;\nconst effectCreationTime = effect._stats.createdTime\nif (event.trigger === \"instant\" && effectCreationTime - templateCallTime < skipTime) return;\n\n// When a creature enters the area for the first time on its TURN\nif (event.trigger === \"instant\" && !actor.myTurnActive) return;\n\nconst details = DC20.DC20Roll.prepareSaveDetails(\"mig\", {against: event.against, statuses: [\"movement\"], rollTitle: event.label});\nconst roll = await DC20.dialog.RollDialog.open(actor, details, {sendToActorOwners: true});\nif (roll && (roll._total < event.against)) {\n  const distance = Math.floor((event.against - roll._total)/5) + 1 + increasedPush;\n  let message = `Actor ${actor.name} should be pushed ${distance} Spaces in random direction horizontally`;\n  if (updraft) message += ` and ${updraft} Spaces upward.`\n  DC20.dialog.SimplePopup.info(\"Tornado - Save Failed\", [message]);\n\n  // Apply Storm Core\n  if (stormCore) {\n    let dmg = {\n      value: stormCore,\n      source: \"Storm Core\",\n      type: \"corrosion\"\n    }\n    DC20.DC20Target.quickApplyDamageFor(actor, dmg, {}, {fromEvent: true})\n  }\n}",
