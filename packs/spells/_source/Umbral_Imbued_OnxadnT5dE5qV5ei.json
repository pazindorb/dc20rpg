    "macros": {
      "AFS6rQ2ekUWivWvu": {
        "command": "const effect = item.effects.get(\"CYPMkXCr6x3JqiLx\");\nif (!effect) return;\neffect.flags.dc20rpg.enhancements = foundry.utils.deepClone(item.system.enhancements)\neffect.system.macro = `\nif (event.trigger === \"instant\") {\n  const enhancements = effect.flags.dc20rpg.enhancements;\n  const damageEnh = enhancements[\"L1o3ELb9xIJey9Kc\"];\n  const dooming = enhancements[\"Xu8JkWylumnzZZ8t\"];\n  const draining = enhancements[\"j87mw00EWlQDPWlf\"];\n\n  const damage = 1 + damageEnh.number;\n  const dmgFormula = new DC20.Formula();\n  dmgFormula.formula = damage + \"\";\n  dmgFormula.type = \"umbral\";\n  const modifications = {\n    addsNewFormula: true,\n    formula: dmgFormula\n  }\n\n  let description = \"<p>You deal + \" + damage + \" Umbral Damage on Martial Attacks</p>\"\n  if (dooming.number > 0) {\n    description += dooming.description;\n    modifications.addsNewRollRequest = true;\n    modifications.rollRequest = dooming.modifications.rollRequest;\n    modifications.addsAgainstStatus = true;\n    modifications.againstStatus = dooming.modifications.againstStatus;\n  }\n\n  if (draining.number > 0) {\n    description += draining.description;\n  }\n\n  const enhancement = {\n    name: \"Umbral Strikes\",\n    img: effect.img,\n    description: description,\n    copyFor: \"isMartialAttack=[true]\",\n    modifications: modifications,\n    repeatable: false\n  }\n  actor.enhancements.add(enhancement, {key: \"umbralImbued\"})\n}\n\n\nif (event.trigger === \"effectRemoved\") {\n  actor.enhancements.delete(\"umbralImbued\");\n}\n`",
        "trigger": "postItemRoll",
