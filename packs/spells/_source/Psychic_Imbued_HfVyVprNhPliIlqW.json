    "macros": {
      "fBQkz0atjH1v9IOI": {
        "command": "const enhancements = item.system.enhancements;\nconst damage = enhancements[\"vZptaWAcBcvC99zt\"];\nconst dazing = enhancements[\"JajCyhVmmu04eh6z\"];\nconst silencing = enhancements[\"du7HE6qMGoqfH7wZ\"];\n\nconst dmgFormula = new DC20.Formula();\ndmgFormula.formula = `${1 + damage.number}`;\ndmgFormula.type = \"psychic\";\n\nconst psychicImbued = new DC20.Enhancement();\npsychicImbued.name = \"Psychic Imbued\";\npsychicImbued.modifications.formula = dmgFormula;\npsychicImbued.modifications.addsNewFormula = true;\npsychicImbued.description = `You deal ${1 + damage.number} Psychic damage on Martial Attacks`;\n\nconst newEnhancements = {\n  [\"-=vZptaWAcBcvC99zt\"]: null,\n  [\"-=9gB4mjjuvh86gFIr\"]: null,\n  [\"-=JajCyhVmmu04eh6z\"]: null,\n  [\"-=du7HE6qMGoqfH7wZ\"]: null,\n  psychicImbued: psychicImbued\n}\nif (dazing.number > 0) {\n  const blueprint = foundry.utils.deepClone(dazing);\n  blueprint.name = \"Psychic Imbued - Dazing Strikes\";\n  blueprint.resources.mana = null;\n  blueprint.number = 0;\n  newEnhancements.dazing = blueprint;\n}\nif (silencing.number > 0) {\n  const blueprint = foundry.utils.deepClone(silencing);\n  blueprint.name = \"Psychic Imbued - Silencing Strikes\";\n  blueprint.resources.mana = null;\n  blueprint.number = 0;\n  newEnhancements.silencing = blueprint;\n}\n\nitem.update({\n  [\"flags.dc20rpg.enhancements\"]: enhancements,\n  [\"system.copyEnhancements.copy\"]: true,\n  [\"system.enhancements\"]: newEnhancements\n})",
        "trigger": "postChatMessageCreated",
        "disabled": false,
        "name": "Prepare Item after roll",
        "title": "",
        "global": false
      },
      "X5L4oCNsK45PWGUm": {
        "command": "if (!off) return;\n\nconst oldEnhancements = item.flags.dc20rpg.enhancements;\nif (!oldEnhancements) return;\nfor (const enh of Object.values(oldEnhancements)) {\n  enh.number = 0;\n}\n\noldEnhancements[\"-=psychicImbued\"] = null;\noldEnhancements[\"-=dazing\"] = null;\noldEnhancements[\"-=silencing\"] = null;\nitem.update({\n  [\"flags.dc20rpg.-=enhancements\"]: null,\n  [\"system.copyEnhancements.copy\"]: false,\n  [\"system.enhancements\"]: oldEnhancements\n})",
        "trigger": "onItemToggle",
        "disabled": false,
        "name": "Reset Item on toggle off",
        "title": "",
        "global": false
      }
