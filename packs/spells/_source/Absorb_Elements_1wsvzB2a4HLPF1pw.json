              "effectKey": "lingeringRetaliation",
              "macro": "const damage = 0;\nconst type = \"fire\";\n\nconst message = game.messages.get(extras.messageId);\nif (!message) return;\n\nlet target = game.actors.tokens[message.speaker.token];\nif (!target) target = game.actors.get(message.speaker.actor);\nif (!target) return;\n\nconst isMelee = await DC20.dialog.SimplePopup.confirm(\"Is that a Melee Attack?\");\nif (!isMelee) return;\n\nlet dmg = {\n  value: damage,\n  source: \"Lingering Retaliation\",\n  type: type\n}\nconst calculationTarget = {\n  system: {damageReduction: target.system.damageReduction}\n}\ndmg = game.dc20rpg.tools.calculateForTarget(calculationTarget, {clear: {...dmg}, modified: {...dmg}}, {isDamage: true})\ngame.dc20rpg.tools.applyDamage(target, dmg.modified, {fromEvent: true});",
