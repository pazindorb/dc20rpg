    "macros": {
      "5TVzag9Frtch8xlG": {
        "command": "const damageEnhancement = item.enhancements.active.get(\"Xxj2h1rTzpBkO5cs\");\nconst cleaveEnhancement = item.enhancements.active.get(\"DQt8zesdtd3ExSiL\");\nconst physicalEnhancement = item.enhancements.active.get(\"t7HgqablCZfROnUu\");\n\n// Configure damage\nconst type = await DC20.dialog.SimplePopup.select(\"Select Damage Type\", CONFIG.DC20RPG.DROPDOWN_DATA.physicalDamageTypes) || \"slashing\";\nconst damage = 2 + (damageEnhancement?.number || 0);\nconst damageFormula = new DC20.Formula();\ndamageFormula.formula = `${damage}`;\ndamageFormula.type = type;\n\nconst updateData = {\n  [\"system.macros.5TVzag9Frtch8xlG.disabled\"]: true, // Disable roll macro\n  [\"system.enhancements.GZqLp7ULqqMMGGNf.hide\"]: true, // Range\n  [\"system.enhancements.Xxj2h1rTzpBkO5cs.hide\"]: true, // Damage\n  [\"system.enhancements.O1IhdNpTnSS9ypwj.hide\"]: true, // Effortless\n  [\"system.enhancements.t7HgqablCZfROnUu.hide\"]: true, // Physical Effect\n  [\"system.enhancements.DQt8zesdtd3ExSiL.hide\"]: true, // Cleave\n  [\"system.enhancements.iCIlfHENQ52icA28.hide\"]: false, // Free Attack\n  [\"system.enhancements.njoGIlojUFAa1sq1.hide\"]: !!!cleaveEnhancement, // Cleave - weapon\n  [\"system.formulas.arcaneWeapon\"]: damageFormula,\n  [\"system.costs.resources.mana\"]: null,\n  [\"system.actionType\"]: \"attack\",\n  [\"system.duration.type\"]: \"\",\n}\n\n// Configure Physical Effect\nif (physicalEnhancement) {\n  let status = \"bleeding\";\n  if (type === \"piercing\") status = \"impaired\";\n  if (type === \"bludgeoning\")  status = \"prone\";\n  updateData[\"system.enhancements.a3tu4XYsLB3hTZei.hide\"] = false;\n  updateData[\"system.enhancements.a3tu4XYsLB3hTZei.modifications.addsEffect.system.changes\"] = [{\n    key: `system.statusResistances.${status}.vulnerability`,\n    mode: 2,\n    value: 1\n  }]\n}\n\nitem.update(updateData)",
        "trigger": "postItemRoll",
        "disabled": false,
        "name": "Configure Weapon Attack",
        "title": "",
        "global": false
      },
      "11uZFzy7bdTKDGKn": {
        "command": "if (!off) return;\n\nconst updateData = {\n  [\"system.macros.5TVzag9Frtch8xlG.disabled\"]: false, // Enable roll macro\n  [\"system.enhancements.GZqLp7ULqqMMGGNf.hide\"]: false, // Range\n  [\"system.enhancements.Xxj2h1rTzpBkO5cs.hide\"]: false, // Damage\n  [\"system.enhancements.O1IhdNpTnSS9ypwj.hide\"]: false, // Effortless\n  [\"system.enhancements.t7HgqablCZfROnUu.hide\"]: false, // Physical Effect\n  [\"system.enhancements.DQt8zesdtd3ExSiL.hide\"]: false, // Cleave\n  [\"system.enhancements.iCIlfHENQ52icA28.hide\"]: true, // Free Attack\n  [\"system.enhancements.njoGIlojUFAa1sq1.hide\"]: true, // Cleave - weapon\n  [\"system.enhancements.a3tu4XYsLB3hTZei.hide\"]: true, // Physical Effect - weapon\n  [\"system.formulas.-=arcaneWeapon\"]: null,\n  [\"system.costs.resources.mana\"]: 1,\n  [\"system.actionType\"]: \"\",\n  [\"system.duration.type\"]: \"sustain\",\n}\nitem.update(updateData)",
