    "macros": {
      "zwTZo2oLB2v347tu": {
        "command": "const effect = item.getEffectByKey(\"bless\");\nif (!effect) return;\n\nconst enhancements = item.enhancements.active;\n\n// Greater Bless Active\nconst greaterBless = enhancements.get(\"zDwy7sCYKiKS5O3O\");\nif (greaterBless) {\n  effect.flags.dc20rpg = {greaterBless: greaterBless.number};\n}\n\n// Full Bless Active - nothing more to do here\nif (enhancements.get(\"hmc5tmMPtjnFpXhT\")) return;\n\n// Select Blessing\nlet blessing = await DC20.dialog.SimplePopup.select(\"Select Blessing\", {attacks: \"Attacks\", saves: \"Saves\"});\n\nconst newChanges = [];\nfor (const change of effect.system.changes) {\n  if (change.key.includes(\"events\")) newChanges.push(change);\n  if (change.key.includes(\".saves.\") && blessing === \"saves\") newChanges.push(change);\n  if (change.key.includes(\".deathSave\") && blessing === \"saves\") newChanges.push(change);\n  if (change.key.includes(\".attack\") && blessing === \"attacks\") newChanges.push(change);\n}\neffect.system.changes = newChanges;",
        "trigger": "preItemRoll",
        "disabled": false,
        "name": "Handle Bless Selection",
        "title": "",
        "global": false
      }
