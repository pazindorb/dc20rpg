        "effectKey": "bless",
        "macro": "const greaterBless = effect.flags.dc20rpg?.greaterBless || 0;\nconst message = game.messages.get(effect.system.chatMessageId);\nif (!message) return;\n\nconst rollTotal = message.winningRoll?.total;\n\nlet dice = 6 + (2 * greaterBless);\nif (rollTotal < 15) dice -= 2;\nelse if (rollTotal >= 25) dice += 2;\nif (dice > 12) dice = 12;\n\nconst changes = effect.system.changes;\nfor (const change of changes) {\n  change.value = change.value.replace(\"#DICE#\", `d${dice}`);\n}\neffect.update({[\"system.changes\"]: changes});",
