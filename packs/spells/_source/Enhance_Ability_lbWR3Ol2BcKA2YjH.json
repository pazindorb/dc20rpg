        "effectKey": "enhanceAbility",
        "macro": "const greaterEnhance = effect.flags.dc20rpg?.greaterEnhance || 0;\nconst message = game.messages.get(effect.system.chatMessageId);\nif (!message) return;\n\nconst rollTotal = message.system.coreRollTotal;\n\nlet dice = 6 + (2 * greaterEnhance);\nif (rollTotal < 15) dice -= 2;\nelse if (rollTotal >= 25) dice += 2;\nif (dice > 12) dice = 12;\n\nconst changes = effect.changes;\nfor (const change of changes) {\n  change.value = change.value.replace(\"#DICE#\", `d${dice}`);\n}\neffect.update({changes: changes});",
