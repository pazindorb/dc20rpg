    "macros": {
      "zwTZo2oLB2v347tu": {
        "command": "const effect = item.getEffectByKey(\"enhanceAbility\");\nif (!effect) return;\n\nconst enhancements = item.enhancements.active;\n\n// Greater Bless Active\nconst greaterEnhance = enhancements.get(\"zDwy7sCYKiKS5O3O\");\nif (greaterEnhance) {\n  effect.flags.dc20rpg = {greaterEnhance: greaterEnhance.number};\n}\n\n// Full Enhance Active - nothing more to do here\nif (enhancements.get(\"hmc5tmMPtjnFpXhT\")) return;\n\n// Select Enhance\nlet enhance = await DC20.dialog.SimplePopup.select(\"Select Attributes\", {phy: \"Physical\", men: \"Mental\"});\n\nconst newChanges = [];\nfor (const change of effect.changes) {\n  if (change.key.includes(\"events\")) newChanges.push(change);\n\n  if (change.key.includes(\".mig\") && enhance === \"phy\") newChanges.push(change);\n  if (change.key.includes(\".agi\") && enhance === \"phy\") newChanges.push(change);\n  if (change.key.includes(\".mar\") && enhance === \"phy\") newChanges.push(change);\n\n  if (change.key.includes(\".int\") && enhance === \"men\") newChanges.push(change);\n  if (change.key.includes(\".cha\") && enhance === \"men\") newChanges.push(change);\n  if (change.key.includes(\".spe\") && enhance === \"men\") newChanges.push(change);\n}\neffect.changes = newChanges;",
        "trigger": "preItemRoll",
        "disabled": false,
        "name": "Handle Enhance Ability Selection",
        "title": "",
        "global": false
      }
    },
