        "command": "const effect = item.effects.get(\"giOhYQnjsOsLGLY6\");\nif (effect) await effect.update({[\"system.addToChat\"]: false});\n\nconst shockDamage = new DC20.Formula()\nshockDamage.formula = \"1\";\nshockDamage.type = \"lightning\"\nconst rollRequest = foundry.utils.deepClone(item.system.rollRequests[\"cQAxs4jbupDS2lY3\"]);\nawait item.update({\n  [\"system.rollRequests.-=cQAxs4jbupDS2lY3\"]: null,\n  [\"system.actionType\"]: \"other\",\n  [\"system.formulas.shockDamage\"]: shockDamage,\n  [\"system.enhancements.jH2ou3NVrsRPBBnF.hide\"]: true,\n  [\"system.enhancements.w63r2LkMw7NZ1sGy.hide\"]: true,\n  [\"system.enhancements.dR17vjSNbQhIdKxV.hide\"]: true,\n  [\"system.enhancements.DRFtBru6AFOBvcaz.hide\"]: false,\n  [\"system.enhancements.0ByNZNQeK71FGrlp.hide\"]: false,\n})\nawait item.roll()\n\nitem.update({\n  [\"system.rollRequests.cQAxs4jbupDS2lY3\"]: rollRequest,\n  [\"system.actionType\"]: \"check\",\n  [\"system.formulas.-=shockDamage\"]: null,\n  [\"system.enhancements.jH2ou3NVrsRPBBnF.hide\"]: false,\n  [\"system.enhancements.w63r2LkMw7NZ1sGy.hide\"]: false,\n  [\"system.enhancements.dR17vjSNbQhIdKxV.hide\"]: false,\n  [\"system.enhancements.DRFtBru6AFOBvcaz.hide\"]: true,\n  [\"system.enhancements.0ByNZNQeK71FGrlp.hide\"]: true,\n})\nif (effect) effect.update({[\"system.addToChat\"]: true});",
