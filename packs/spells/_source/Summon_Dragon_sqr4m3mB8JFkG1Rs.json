    "macros": {
      "af4lJBN2Lg64HbUl": {
        "command": "const summon = await fromUuid(\"Compendium.dc20rpg.summons.Actor.Kly5OSRDhTJ4ZNni\")\nif (!summon) {\n  ui.notifications.warn(\"Summon not found fix the macro.\");\n  return;\n}\n\nconst actorData = summon.toObject();\nactorData.ownership[game.user.id] = 3;\nactorData.system.companionOwnerId = actor.id;\n\nif (Actor.canUserCreate(game.user)) Actor.create(actorData);\nelse {\n  const activeGM = game.users.activeGM;\n  if (!activeGM) {\n    ui.notifications.error(\"You have no permissions to create a new Actor and there is no active GM. Actor cannot be created.\");\n    return;\n  }\n\n  game.socket.emit('system.dc20rpg', { \n    actorData: actorData,\n    gmUserId: activeGM.id,\n    type: \"createActor\"\n  });\n}",
        "trigger": "onDemand",
