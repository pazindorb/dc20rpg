<div class="properties">
  <div class="grid grid-4col grid-gap-5 margin-top-3">
    {{#each properties as |property key|}}
      {{#if property.display}}
      <a class="activable-box journal-tooltip {{#ifCond key '===' 'multiFaceted'}}disabled{{else}}property-toggle{{/ifCond}} {{#if property.active}} active {{/if}}"
            data-header="{{property.label}}  ({{property.cost}})" data-uuid="{{property.journalUuid}}"
            data-key="{{key}}"
            {{#ifCond key '===' 'multiFaceted'}} title="{{localize "dc20rpg.item.sheet.config.editableOnlyOnCreator"}}" {{/ifCond}}
      >{{property.label}}
      </a>
      {{/if}}
    {{/each}}
  </div>

  {{!-- {{#if system.properties.reload.active}}
  <div class="row margin-top-5">
    <span>{{localize "dc20rpg.item.sheet.config.reload"}}</span>
    <input type="text" name="system.properties.reload.value" value="{{system.properties.reload.value}}" data-dtype="Number" placeholder="-">
  </div>
  {{/if}} --}}

  {{#if system.properties.pdIncrease.active}}
  <div class="row margin-top-5">
    <span>{{localize "dc20rpg.item.sheet.config.pdIncrease"}}</span>
    <input type="text" name="system.properties.pdIncrease.value" value="{{system.properties.pdIncrease.value}}" data-dtype="Number" placeholder="-">
  </div>
  {{/if}}

  {{#if system.properties.adIncrease.active}}
  <div class="row margin-top-5">
    <span>{{localize "dc20rpg.item.sheet.config.adIncrease"}}</span>
    <input type="text" name="system.properties.adIncrease.value" value="{{system.properties.adIncrease.value}}" data-dtype="Number" placeholder="-">
  </div>
  {{/if}}

  {{#if system.properties.reach.active}}
  <div class="row margin-top-5">
    <span>{{localize "dc20rpg.item.sheet.config.reach"}}</span>
    <input type="text" name="system.properties.reach.value" value="{{system.properties.reach.value}}" data-dtype="Number" placeholder="-">
  </div>
  {{/if}}
</div>