<div class="tab target-modifier-tab padding-7" data-group="advanced" data-tab="target-modifier">
  <div class="sub-header">
    <span>{{localize "dc20rpg.item.sheet.targetModifiers.title"}}</span>
    <a class="add-target-modifier fa-solid fa-plus fa-lg" title="{{localize "dc20rpg.item.sheet.targetModifiers.addTargetModifier"}}"></a>
  </div>

  {{#each system.targetModifiers as |modifier key|}}
  <div class="big-table margin-top-10">
    <div class="sub-header">
      <input type="text" name="system.targetModifiers.{{key}}.name" value="{{modifier.name}}" placeholder="-" title="{{localize "dc20rpg.item.sheet.targetModifiers.displayName"}}">
      <div>
        {{#if @root.system.toggle.toggleable}}
        <a class="fa-lg activable margin-right-5 {{#if modifier.linkWithToggle}}fa-solid fa-square-check{{else}}fa-regular fa-square{{/if}}" 
            data-path="system.targetModifiers.{{key}}.linkWithToggle" title="{{localize "dc20rpg.item.sheet.targetModifiers.linkWithToggleTitle"}}"></a>
        {{/if}}
        <a class="remove-target-modifier fa-solid fa-square-minus fa-lg margin-right-5" data-key="{{key}}" title="{{localize "dc20rpg.item.sheet.targetModifiers.removeTargetModifier"}}"></a>
      </div>
    </div>
  <div class="content-wrapper">
    <div class="row margin-top-3">
      <span>{{localize "dc20rpg.item.sheet.targetModifiers.useFor"}}</span>
      <input class="formula" type="text" name="system.targetModifiers.{{key}}.useFor" value="{{modifier.useFor}}">
    </div>
    <div class="row margin-top-3">
      <span>{{localize "dc20rpg.item.sheet.targetModifiers.condition"}}</span>
      <a class="target-modifier-macro-edit fa-pen-to-square fa-solid fa-lg {{#unless modifier.condition}}empty{{/unless}}" data-key="{{key}}" title="{{localize "dc20rpg.item.sheet.targetModifiers.condition"}}"></a>
    </div>

    {{!-- Bonus dmg/heal --}}
    <hr class="margin-top-5" />
    <div class="row margin-top-5">
      <span>{{localize "dc20rpg.item.sheet.targetModifiers.bonus"}}</span>
      <input class="formula" type="text" name="system.targetModifiers.{{key}}.bonus" value="{{modifier.bonus}}">
    </div>
    {{!-- Adds new Formula --}}
    <div class="row margin-top-5">
      <span>{{localize "dc20rpg.item.sheet.enh.addsNewFormula"}}</span>
      <a class="activable fa-lg {{#if modifier.addsNewFormula}}fa-square-check fa-solid{{else}}fa-regular fa-square{{/if}}" data-path="system.targetModifiers.{{key}}.addsNewFormula"></a>
    </div>
    {{#if modifier.addsNewFormula}}
    <div class="row margin-top-3">
      <span>{{localize "dc20rpg.item.sheet.enh.formulaCategory"}}</span>
      <select class="margin-left-3" name="system.targetModifiers.{{key}}.formula.category" title="{{localize "dc20rpg.item.sheet.enh.formulaCategory"}}">
        {{selectOptions @root.config.DROPDOWN_DATA.formulaCategories selected=modifier.formula.category}}
      </select>
    </div>
    <div class="row margin-top-3">
      <div class="left-part-row">
        <span class="{{modifier.formula.category}}-formula">{{varLocalize "dc20rpg.item.sheet.formulas." modifier.formula.category ""}}</span>
        <a class="activable margin-right-3 fa-solid fa-solid {{#if modifier.formula.dontMerge}}fa-box{{else}}fa-boxes-stacked{{/if}}" data-path="system.targetModifiers.{{key}}.formula.dontMerge" 
          {{#if modifier.formula.dontMerge}}title="{{localize "dc20rpg.item.sheet.formulas.dontMerge"}}"{{else}}title="{{localize "dc20rpg.item.sheet.formulas.merge"}}"{{/if}} ></a>
      </div>
      <div class="right-part-row">
        <input type="text" name="system.targetModifiers.{{key}}.formula.formula" value="{{modifier.formula.formula}}">
        <select class="margin-left-3" name="system.targetModifiers.{{key}}.formula.type" title="{{varLocalize "dc20rpg.item.sheet.formulas." modifier.formula.category "type"}}">
          {{#ifCond modifier.formula.category '===' "damage"}}
          {{selectOptions @root.config.DROPDOWN_DATA.damageTypes selected=modifier.formula.type blank=""}}
          {{else}}
          {{selectOptions @root.config.DROPDOWN_DATA.healingTypes selected=modifier.formula.type blank=""}}
          {{/ifCond}}
        </select>
        {{#ifCond modifier.formula.category "===" "damage"}}
        <select class="margin-left-3" name="system.targetModifiers.{{key}}.formula.overrideDefence" title="{{localize "dc20rpg.item.sheet.formulas.overrideDefence"}}">
          {{selectOptions @root.config.DROPDOWN_DATA.defences selected=modifier.formula.overrideDefence blank=""}}
        </select>
        {{/ifCond}}
      </div>
    </div>
    {{/if}}
    {{!-- Ignore DR --}}
    <hr class="margin-top-5" />
    <div class="row margin-top-5">
      <span>{{localize "dc20rpg.item.sheet.targetModifiers.ignoreDR"}}</span>
      <div class="right-part-row">
        <a class="activable margin-left-5 fa-lg fa-shield {{#if modifier.flags.ignorePdr}}fa-solid{{else}}fa-regular{{/if}}" 
            data-path="system.targetModifiers.{{key}}.flags.ignorePdr" title="{{localize "dc20rpg.item.sheet.targetModifiers.ignorePDR"}}"></a>
        <a class="activable margin-left-5 fa-lg fa-fire-flame-curved {{#if modifier.flags.ignoreEdr}}fa-solid{{else}}fa-regular{{/if}}" 
            data-path="system.targetModifiers.{{key}}.flags.ignoreEdr" title="{{localize "dc20rpg.item.sheet.targetModifiers.ignoreEDR"}}"></a>
        <a class="activable margin-left-5 fa-lg fa-brain {{#if modifier.flags.ignoreMdr}}fa-solid{{else}}fa-regular{{/if}}" 
            data-path="system.targetModifiers.{{key}}.flags.ignoreMdr" title="{{localize "dc20rpg.item.sheet.targetModifiers.ignoreMDR"}}"></a>
      </div>
    </div>
    {{!-- Ignore Resistance --}}
    <div class="row margin-top-3">
      <span>{{localize "dc20rpg.item.sheet.targetModifiers.ignoreResistance"}}</span>
      <select class="multi-select" data-path="system.targetModifiers.{{key}}.flags.ignoreResistance">
        {{selectOptions @root.config.DROPDOWN_DATA.damageResistances blank=""}}
      </select>
    </div>
    <div class="selected-options margin-top-2">
      {{#each modifier.flags.ignoreResistance}}
      <div class="option">
        <span>{{labelFromKey this @root.config.DROPDOWN_DATA.damageResistances}}</span>
        <a class="margin-left-3 multi-select-remove fa-solid fa-xmark" data-path="system.targetModifiers.{{key}}.flags.ignoreResistance" data-key="{{this}}" title="{{localize "dc20rpg.item.sheet.check.removeCheckOption"}}"></a>
      </div>
      {{/each}}
    </div>
    {{!-- Ignore Immunity --}}
    <div class="row margin-top-3">
      <span>{{localize "dc20rpg.item.sheet.targetModifiers.ignoreImmune"}}</span>
      <select class="multi-select" data-path="system.targetModifiers.{{key}}.flags.ignoreImmune">
        {{selectOptions @root.config.DROPDOWN_DATA.damageResistances blank=""}}
      </select>
    </div>
    <div class="selected-options margin-top-2">
      {{#each modifier.flags.ignoreImmune}}
      <div class="option">
        <span>{{labelFromKey this @root.config.DROPDOWN_DATA.damageResistances}}</span>
        <a class="margin-left-3 multi-select-remove fa-solid fa-xmark" data-path="system.targetModifiers.{{key}}.flags.ignoreImmune" data-key="{{this}}" title="{{localize "dc20rpg.item.sheet.check.removeCheckOption"}}"></a>
      </div>
      {{/each}}
    </div>

    {{!-- Adds Roll Request --}}
    <hr class="margin-top-5" />
    <div class="row margin-top-5">
      <span>{{localize "dc20rpg.item.sheet.enh.addsNewRollRequest"}}</span>
      <a class="activable fa-lg {{#if modifier.addsNewRollRequest}}fa-square-check fa-solid{{else}}fa-regular fa-square{{/if}}" data-path="system.targetModifiers.{{key}}.addsNewRollRequest"></a>
    </div>
    {{#if modifier.addsNewRollRequest}}
      <div class="row margin-top-3">
        <span>{{localize "dc20rpg.item.sheet.rollRequests.category"}}</span>
        <select name="system.targetModifiers.{{key}}.rollRequest.category">
          {{selectOptions @root.config.DROPDOWN_DATA.rollRequestCategory selected=modifier.rollRequest.category blank=""}}
        </select>
      </div>

      {{!-- Contest --}}
      {{#ifCond modifier.rollRequest.category '===' "contest"}}
      <div class="row margin-top-3">
        <span>{{localize "dc20rpg.item.sheet.rollRequests.contestedKey"}}</span>
        <select name="system.targetModifiers.{{key}}.rollRequest.contestedKey">
          {{selectOptions @root.config.ROLL_KEYS.contests selected=modifier.rollRequest.contestedKey blank=""}}
        </select>
      </div>
      {{/ifCond}}

      {{!-- Save --}}
      {{#ifCond modifier.rollRequest.category '===' "save"}}
      <div class="row margin-top-3">
        <span>{{localize "dc20rpg.item.sheet.rollRequests.saveKey"}}</span>
        <select name="system.targetModifiers.{{key}}.rollRequest.saveKey">
          {{selectOptions @root.config.ROLL_KEYS.saveTypes selected=modifier.rollRequest.saveKey blank=""}}
        </select>
      </div>
      <div class="row margin-top-3">
        <span>{{localize "dc20rpg.item.sheet.rollRequests.dc"}}</span>
        <div class="right-part-row">
          <input {{#ifCond modifier.rollRequest.dcCalculation  '!==' "flat"}} disabled {{/ifCond}} class="margin-right-3" type="text" name="system.targetModifiers.{{key}}.rollRequest.dc" value="{{modifier.rollRequest.dc}}" data-dtype="Number" placeholder="-">
          <select name="system.targetModifiers.{{key}}.rollRequest.dcCalculation">
            {{selectOptions @root.config.DROPDOWN_DATA.dcCalculationTypes selected=modifier.rollRequest.dcCalculation}}
          </select>
          {{#if (arrayIncludes modifier.rollRequest.dcCalculation arrayString="prime mig agi int cha")}}
            <a class="activable margin-left-3" data-path="system.targetModifiers.{{key}}.rollRequest.addMastery" title="{{localize "dc20rpg.item.sheet.rollRequests.addMastery"}}">
              <i class="fa-lg {{#if modifier.rollRequest.addMastery}}fa-square-check fa-solid{{else}}fa-regular fa-square{{/if}}"></i>
            </a>
          {{/if}}
        </div>
      </div>
      {{/ifCond}}
    {{/if}}

    {{!-- Add Effect --}}
    <hr class="margin-top-5" />
    <div class="row margin-top-5">
      <span>{{localize "dc20rpg.item.sheet.targetModifiers.addEffect"}}</span>
      <div class="right-part-row">
        {{#if modifier.effect}} 
        <a class="margin-right-5 margin-top-5 remove-effect-from fa-lg fa-square-minus fa-solid" data-type="targetModifier" data-key="{{key}}"></a>
        <img src="{{modifier.effect.img}}" class="edit-effect-on" data-type="targetModifier" data-key="{{key}}" title="{{localize "dc20rpg.sheet.effects.edit"}}"/>
        {{else}}
        <a class="add-effect-to fa-lg fa-square-plus fa-solid" data-type="targetModifier" data-key="{{key}}"></a>
        {{/if}}
      </div>
    </div>
  </div>
  {{/each}}
</div>