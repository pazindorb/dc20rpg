<section class="item-sheet-section tab config standard-form {{tabs.config.cssClass}}" data-group="sheet" data-tab="config">
<div class="scrollable">

  {{!-- Item Specific Config --}}
  <div class="item-specific-config">
    {{!-- Weapon Specific --}}
    {{#ifCond type '===' "weapon"}}
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.weapon.weaponType"}}</label>
        <select name="system.weaponType">
          {{selectOptions @root.config.DROPDOWN_DATA.weaponTypes selected=system.weaponType blank=""}}
        </select>
      </div>
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.weapon.weaponStyle"}}</label>
        <select name="system.weaponStyle">
          {{selectOptions @root.config.DROPDOWN_DATA.weaponStyles selected=system.weaponStyle blank=""}}
        </select>
      </div>
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.weapon.unarmedStrike"}}</label>
        <input type="checkbox" name="system.unarmedStrike" {{checked system.unarmedStrike}}/>
      </div>
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.weapon.naturalWeapon"}}</label>
        <input type="checkbox" name="system.naturalWeapon" {{checked system.naturalWeapon}}/>
      </div>
    {{/ifCond}}

    {{!-- Equipment Specific --}}
    {{#ifCond type '===' "equipment"}}
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.equipment.equipmentType"}}</label>
        <select name="system.equipmentType">
          {{selectOptions @root.config.DROPDOWN_DATA.equipmentTypes selected=system.equipmentType blank=""}}
        </select>
      </div>
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.equipment.impactfulUnarmedStries"}}</label>
        <input type="checkbox" name="system.impactfulUnarmedStries" {{checked system.impactfulUnarmedStries}}/>
      </div>
    {{/ifCond}}

    {{!-- Consumbale Specific --}}
    {{#ifCond type '===' "consumable"}}
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.consumable.consumableType"}}</label>
        <select name="system.consumableType">
          {{selectOptions @root.config.DROPDOWN_DATA.consumableTypes selected=system.consumableType blank=""}}
        </select>
      </div>
      {{#ifCond system.consumableType '===' "ammunition"}}
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.consumable.overridenDamageType"}}</label>
        <select name="system.overridenDamageType">
          {{selectOptions @root.config.DROPDOWN_DATA.damageTypes selected=system.overridenDamageType blank=""}}
        </select>
      </div>
      {{/ifCond}}
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.consumable.consumeOnUse"}}</label>
        <input type="checkbox" name="system.consume" {{checked system.consume}}/>
      </div>
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.consumable.deleteOnZero"}}</label>
        <input type="checkbox" name="system.deleteOnZero" {{checked system.deleteOnZero}}/>
      </div>
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.consumable.showAsResource"}}</label>
        <input type="checkbox" name="system.showAsResource" {{checked system.showAsResource}}/>
      </div>
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.consumable.attunementRequired"}}</label>
        <input type="checkbox" name="system.properties.attunement.active" {{checked system.properties.attunement.active}}/>
      </div>
    {{/ifCond}}

    {{!-- Inventory specific item --}}
    {{#if system.inventory}}
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.config.predefined"}}</label>
        <select name="system.statuses.slotLink.predefined">
          {{selectOptions @root.config.DROPDOWN_DATA.equipmentSlots selected=system.statuses.slotLink.predefined blank=""}}
        </select>
      </div>
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.config.stackable"}}</label>
        <input type="checkbox" name="system.stackable" {{checked system.stackable}}/>
      </div>
    {{/if}}

    {{!-- Spell Specific --}}
    {{#ifCond type '===' "spell"}}
    <div class="form-group margin-top-5">
      <label>{{localize "dc20rpg.item.sheet.spell.spellType"}}</label>
      <select name="system.spellType">
        {{selectOptions @root.config.DROPDOWN_DATA.spellTypes selected=system.spellType blank=""}}
      </select>
    </div>
    
    <div class="form-group margin-top-5">
      <label>{{localize "dc20rpg.item.sheet.spell.spellSchool"}}</label>
      <select name="system.spellSchool">
        {{selectOptions @root.config.DROPDOWN_DATA.spellSchools selected=system.spellSchool blank=""}}
      </select>
    </div>

    {{!-- Spell Tags --}}
    <div class="multi-select-wrapper">
      <div class="form-group margin-top-5 ">
        <label>{{localize "dc20rpg.item.sheet.spell.spellTags"}}</label>
        <select class="multi-select" data-cType="multi-select" data-path="system.spellTags">
          {{selectOptions @root.config.DROPDOWN_DATA.spellTags blank=""}}
        </select>
      </div>
      <div class="selected-options">
        {{#each system.spellTags as |option key|}}
          <div class="option">
            <span>{{option}}</span>
            <a class="margin-left-3 fa-solid fa-xmark" data-action="multiSelectRemove" data-path="system.spellTags" data-key="{{key}}" data-tooltip="{{localize "dc20rpg.item.sheet.spell.removeSpellTag"}}"></a>
          </div>
        {{/each}}
      </div>
    </div>
    {{/ifCond}}

    {{!-- Maneuver Specific --}}
    {{#ifCond type '===' "maneuver"}}
    <div class="form-group margin-top-5">
      <label>{{localize "dc20rpg.item.sheet.maneuver.maneuverType"}}</label>
      <select name="system.maneuverType">
        {{selectOptions @root.config.DROPDOWN_DATA.maneuverTypes selected=system.maneuverType blank=""}}
      </select>
    </div>
    <div class="form-group margin-top-5">
      <label>{{localize "dc20rpg.item.sheet.config.useWeapon"}}</label>
      <input type="checkbox" name="system.usesWeapon.weaponAttack" {{checked system.usesWeapon.weaponAttack}}/>
    </div>
    {{/ifCond}}

    {{!-- Feature Specific --}}
    {{#ifCond type '===' "feature"}}
    <div class="form-group margin-top-5">
      <label>{{localize "dc20rpg.item.sheet.feature.featureType"}}</label>
      <select name="system.featureType">
        {{selectOptions @root.config.DROPDOWN_DATA.featureSourceTypes selected=system.featureType blank=""}}
      </select>
    </div>
    <div class="form-group margin-top-5">
      <label>{{localize "dc20rpg.item.sheet.feature.featureOrigin"}}</label>
      <input {{#if @root.featureSourceItems}}disabled{{/if}} type="text" name="system.featureOrigin" value="{{system.featureOrigin}}" placeholder="-">
    </div>
    {{#if featureSourceItems}}
    <div class="form-group margin-top-5" data-tooltip="{{localize "dc20rpg.item.sheet.feature.featureSourceItemTooltip"}}">
      <label>{{localize "dc20rpg.item.sheet.feature.featureSourceItem"}}</label>
      <select name="system.featureSourceItem">
        {{selectOptions featureSourceItems selected=system.featureSourceItem blank=""}}
      </select>
    </div>
    {{/if}}
    <div class="form-group margin-top-5">
      <label>{{localize "dc20rpg.item.sheet.config.staminaFeature"}}</label>
      <input type="checkbox" name="system.staminaFeature" {{checked system.staminaFeature}}/>
    </div>
    <div class="form-group margin-top-5">
      <label>{{localize "dc20rpg.item.sheet.config.flavorFeature"}}</label>
      <input type="checkbox" name="system.flavorFeature" {{checked system.flavorFeature}}/>
    </div>
    <div class="form-group margin-top-5">
      <label>{{localize "dc20rpg.item.sheet.config.useWeapon"}}</label>
      <input type="checkbox" name="system.usesWeapon.weaponAttack" {{checked system.usesWeapon.weaponAttack}}/>
    </div>
    {{/ifCond}}

    {{!-- Basic Action Specific --}}
    {{#ifCond type '===' "basicAction"}}
    <div class="form-group margin-top-5">
      <label>{{localize "dc20rpg.item.sheet.basicAction.category"}}</label>
      <select name="system.category">
        {{selectOptions @root.config.DROPDOWN_DATA.basicActionsCategories selected=system.category blank=""}}
      </select>
    </div>
    {{/ifCond}}
  </div>

  {{!-- Properties --}}
  {{#if properties}}
  <div class="properties">
    <div class="sub-header margin-top-10">
      <label>{{localize "dc20rpg.item.sheet.config.itemProperties"}}</label>
      <div class="button-wrapper">
        <a class="fa-solid fa-square-plus fa-lg margin-right-5" data-action="createSubdoc" data-type="property" data-tooltip="{{localize "dc20rpg.item.sheet.properties.add"}}"></a>
        <a class="fa-solid fa-square-check fa-lg margin-right-5" data-action="addStandardProperty" data-tooltip="{{localize "dc20rpg.item.sheet.properties.activate"}}"></a>
        <div class="property-cost" data-tooltip="{{localize "dc20rpg.dialog.weaponCreator.pointsCost"}}"><i class="fa-solid fa-coins"></i> {{propertyCost}}</div>
      </div>
    </div>
    <div class="grid grid-4col grid-gap-5 margin-top-3">
      {{#each properties as |property key|}}
        {{#if property.display}}
        <div style="position: relative;">
          <a class="activable-box {{#ifCond key '===' 'multiFaceted'}}disabled{{/ifCond}} {{#if property.active}}active{{/if}}"
                data-header="{{property.label}}  ({{property.cost}})" data-uuid="{{property.journalUuid}}"
                data-key="{{key}}" data-hover="tooltip" data-tooltip-type="journal"
                {{#ifCond key '===' 'multiFaceted'}} data-tooltip="{{localize "dc20rpg.item.sheet.config.editableOnlyOnCreator"}}" {{/ifCond}}
                {{#ifCond key '!==' 'multiFaceted'}} data-cType="activable" data-path="{{property.updatePath}}.active" {{/ifCond}}
          >{{property.label}}
          </a>
          {{#if property.custom}}
          <a class="fa-solid fa-xmark property-remove-button" data-action="removeSubdoc" data-type="property" data-key="{{key}}" data-tooltip="{{localize "dc20rpg.item.sheet.properties.remove"}}"></a>
          {{/if}}
        </div>
        {{/if}}
      {{/each}}
    </div>

    {{#if system.properties.pdIncrease.active}}
    <div class="form-group short-form">
      <label>{{localize "dc20rpg.item.sheet.config.pdIncrease"}}</label>
      <input type="text" name="system.properties.pdIncrease.value" value="{{system.properties.pdIncrease.value}}" data-dtype="Number" placeholder="-">
    </div>
    {{/if}}

    {{#if system.properties.adIncrease.active}}
    <div class="form-group short-form">
      <label>{{localize "dc20rpg.item.sheet.config.adIncrease"}}</label>
      <input type="text" name="system.properties.adIncrease.value" value="{{system.properties.adIncrease.value}}" data-dtype="Number" placeholder="-">
    </div>
    {{/if}}

    {{#if system.properties.reach.active}}
    <div class="form-group short-form">
      <label>{{localize "dc20rpg.item.sheet.config.reach"}}</label>
      <input type="text" name="system.properties.reach.value" value="{{system.properties.reach.value}}" data-dtype="Number" placeholder="-">
    </div>
    {{/if}} 
  </div>
  {{/if}}

  {{#ifCond type '===' "spell"}}
    {{!-- Spell Lists --}}
    <div class="spell-list">
      <div class="sub-header margin-top-10">
        <label>{{localize "dc20rpg.item.sheet.spell.spellSources"}}</label>
      </div>
      <div class="grid grid-3col grid-gap-5 margin-top-3">
        {{#each system.spellSource as |list key|}}
          <a class="activable-box {{#if list.active}}active{{/if}}"
                data-cType="activable" data-path="system.spellSource.{{key}}.active"
          >{{labelFromKey key @root.config.DROPDOWN_DATA.spellSources}}
          </a>
        {{/each}}
      </div>
    </div>

    {{!-- Spell Components --}}
    <div class="spell-components">
      <div class="sub-header margin-top-10">
        <label>{{localize "dc20rpg.item.sheet.spell.components"}}</label>
      </div>
      <div class="properties">
        <div class="grid grid-3col grid-gap-5 margin-top-3">
          {{#each system.components as |component key|}}
            <a class="component activable-box activable {{#if component.active}}active{{/if}}"
                  data-cType="activable" data-path="system.components.{{key}}.active"
            >{{labelFromKey key @root.config.DROPDOWN_DATA.components}}
            </a>
          {{/each}}
        </div>
      </div>
      {{#if system.components.material.active}}
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.spell.material"}} </label>
        <input class="formula" type="text" name="system.components.material.description" value="{{system.components.material.description}}" placeholder="-">
      </div>
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.spell.materialCost"}} </label>
        <input class="small-input" type="text" name="system.components.material.cost" value="{{system.components.material.cost}}" data-dtype="Number" placeholder="-">
      </div>
      <div class="form-group margin-top-5">
        <label>{{localize "dc20rpg.item.sheet.spell.materialConsume"}}</label>
        <input type="checkbox" name="system.components.material.consumed" {{checked system.components.material.consumed}}/>
      </div>
      {{/if}}
    </div>
  {{/ifCond}}

  {{!-- Base Item Config --}}
  <div class="base-config margin-top-10">
    <div class="sub-header">
      <label>{{localize "dc20rpg.item.sheet.basicConfig.title"}}</label>
      <a class="fa-solid {{#if sheetFlags.basicConfigClosed}}fa-square-caret-down{{else}}fa-square-caret-up{{/if}} fa-lg" data-action="sheetEdit" data-key="basicConfigClosed"></a>
    </div>
    {{#unless sheetFlags.basicConfigClosed}}
    <div class="content-wrapper">
      <div class="form-group">
        <label>{{localize "dc20rpg.item.sheet.config.isReaction"}}</label>
        <input type="checkbox" name="system.isReaction" {{checked system.isReaction}}/>
      </div>
      <div class="form-group">
        <label>{{localize "dc20rpg.item.sheet.config.toggleable"}}</label>
        <input type="checkbox" name="system.toggle.toggleable" {{checked system.toggle.toggleable}}/>
        <p class="hint">{{localize "dc20rpg.item.sheet.config.toggleableTitle"}}</p>
      </div>
      <div class="form-group">
        <label>{{localize "dc20rpg.item.sheet.config.toggleOnRoll"}}</label>
        <input type="checkbox" name="system.toggle.toggleOnRoll" {{checked system.toggle.toggleOnRoll}}/>
        <p class="hint">{{localize "dc20rpg.item.sheet.config.toggleOnRollTitle"}}</p>
      </div>
      <div class="form-group">
        <label>{{localize "dc20rpg.item.sheet.config.offOnSustainDrop"}}</label>
        <input type="checkbox" name="system.toggle.offOnSustainDrop" {{checked system.toggle.offOnSustainDrop}}/>
      </div>
      <div class="form-group short-form">
        <label>{{localize "dc20rpg.item.sheet.config.choicePointCost"}}</label>
        <input type="number" name="system.choicePointCost" value="{{system.choicePointCost}}" placeholder="-" data-dtype="Number">
      </div>
      <div class="form-group">
        <label>{{localize "dc20rpg.item.sheet.config.itemKey"}}</label>
        <input type="text" name="system.itemKey" value="{{system.itemKey}}" placeholder="-">
        <p class="hint">{{localize "dc20rpg.item.sheet.config.itemKeyTitle"}}</p>
      </div>
      <div class="form-group">
        <label>{{localize "dc20rpg.item.sheet.config.itemRequirement"}}</label>
        <input type="text" name="system.requirements.items" value="{{system.requirements.items}}" placeholder="-">
        <p class="hint">{{localize "dc20rpg.item.sheet.config.itemRequirementTitle"}}</p>
      </div>
        <div class="form-group short-form">
        <label>{{localize "dc20rpg.item.sheet.config.minLevel"}}</label>
        <input type="text" name="system.requirements.level" value="{{system.requirements.level}}" placeholder="-" data-dtype="Number">
        <p class="hint">{{localize "dc20rpg.item.sheet.config.minLevelTitle"}}</p>
      </div>
      <div class="form-group">
        <label>{{localize "dc20rpg.item.sheet.config.unique"}}</label>
        <input type="checkbox" name="system.requirements.unique" {{checked system.requirements.unique}}/>
        <p class="hint">{{localize "dc20rpg.item.sheet.config.uniqueTitle"}}</p>
      </div>
      <div class="form-group">
        <label>{{localize "dc20rpg.item.sheet.config.quickRoll"}}</label>
        <input type="checkbox" name="system.quickRoll" {{checked system.quickRoll}}/>
      </div>
      <div class="form-group">
        <label>{{localize "dc20rpg.item.sheet.config.skipChatMessage"}}</label>
        <input type="checkbox" name="system.skipChatMessage" {{checked system.skipChatMessage}}/>
      </div>
      <div class="form-group">
        <label>{{localize "dc20rpg.item.sheet.config.hideFromCompendiumBrowser"}}</label>
        <input type="checkbox" name="system.hideFromCompendiumBrowser" {{checked system.hideFromCompendiumBrowser}}/>
      </div>
    </div>
    {{/unless}}
  </div>

</div>
</section>
