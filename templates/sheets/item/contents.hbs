<section class="item-sheet-section tab contents standard-form {{tabs.contents.cssClass}}" data-group="sheet" data-tab="contents">
<div class="scrollable">
  <div class="item-specific-config">
    <div class="form-group margin-top-5">
      <label>{{localize "dc20rpg.item.sheet.container.inventoryOnly"}}</label>
      <input type="checkbox" name="system.inventoryOnly" {{checked system.inventoryOnly}}/>
    </div>
  </div>

  <div class="contents-box margin-top-10">
    {{#each tables as |table tableKey|}}
    {{#if table.notEmpty}}
    <div class="item-list">
      {{!-- Header --}}
      <div class="item-header" style="grid-template-columns: 35px 1fr 120px 50px 30px">
        <div class="column"></div>
        {{!-- Name --}}
        <div class="column name"> <input disabled type="text" value="{{table.label}}"/> </div>
        {{!-- Cost --}}
        <div class="column"><i class="fa-solid fa-coins" data-tooltip="{{localize 'dc20rpg.sheet.itemTable.cost'}}"></i></div>
        {{!-- Quantity --}}
        <div class="column"><i class="fa-solid fa-boxes-stacked" data-tooltip="{{localize 'dc20rpg.sheet.itemTable.quantity'}}"></i></div>
        {{!-- Config --}}
        <div class="column"><i class="fa-solid fa-gear"></i></div>
      </div>
      
      {{!-- Row --}}
      {{#each table.items as |item itemKey|}}
      <div class="item item-row" data-item-key="{{itemKey}}" style="grid-template-columns: 1fr 120px 50px 30px">
        {{!-- Name --}}
        <div class="column name draggable" data-hover="tooltip" data-tooltip-type="item" data-item-key="{{itemKey}}">
          <div class="item-img-wrapper">
            <img src="{{img}}"/>
          </div>
          <div class="item-name">{{name}}</div>
        </div>

        {{!-- Cost --}}
        {{#if item.system.inventory}}
        <div class="column" data-tooltip="{{localize 'dc20rpg.sheet.itemTable.cost'}}">
          <input type="text" value="{{item.system.price.value}}" name="system.contents.{{itemKey}}.system.price.value">
          <select name="system.contents.{{itemKey}}.system.price.currency">
            {{selectOptions @root.config.DROPDOWN_DATA.currencyTypes selected=item.system.price.currency}}
          </select>
        </div>

        {{!-- Quantity --}}
        <div class="column" data-tooltip="{{localize 'dc20rpg.sheet.itemTable.quantity'}}">
          <input type="text" value="{{item.system.quantity}}" name="system.contents.{{itemKey}}.system.quantity">
        </div>
        {{else}}
        {{!-- Non inventory items have no cost or quantity --}}
        <div class="column"></div>
        <div class="column"></div>
        {{/if}}

        <div class="column config">
          <a class="fas fa-x" data-action="removeSubdoc" data-type="itemContent" data-key="{{itemKey}}" data-tooltip="{{localize "dc20rpg.sheet.items.deleteItem"}}"></a>
        </div>
      </div>
      {{/each}}
    </div>
    {{/if}}
    {{/each}}
  </div>
</div>
</section>