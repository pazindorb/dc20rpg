<div class="statuses">
  <div class="status-header">
    {{localize 'dc20rpg.sheet.effects.conditions'}}
  </div>

  <div class="status-table grid grid-4col">
    {{#each statuses as |status key|}}
    {{#unless status.system.hide}}
      <a class="status status-toggle journal-tooltip {{#if status.active}}active{{/if}} {{#if status.effectId}}editable-effect{{/if}}" 
        {{#if status.effectId}}data-effect-id="{{status.effectId}}"{{/if}} data-status-id="{{status.id}}" data-tooltip="{{status.source}}" 
        data-uuid="{{labelFromKey status.id @root.config.SYSTEM_CONSTANTS.JOURNAL_UUID.conditionsJournal}}" data-header="{{status.name}}" data-img="{{status.img}}"
      >
        {{!-- Stackable conditions --}}
        {{#if status.stack}}
        <div class="status-stack">
          <div class="letter-circle-icon">
            <span>{{status.stack}}</span>
          </div>
        </div>
        {{/if}}

        {{!-- Non-stackable conditions --}}
        {{#if status.locked}}
        <div class="status-stack">
          <div class="letter-circle-icon">
            <i class="fa-sm fa-solid fa-lock"></i>
          </div>
        </div>
        {{/if}}

        <div class="status-img"><img src="{{status.img}}"/></div>
        <div class="status-name">{{status.name}}</div>
      </a>
    {{/unless}}
    {{/each}}
  </div>
</div>